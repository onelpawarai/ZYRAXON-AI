{
  "$schema": "https://zyraxon.ai/tui.json",
  "plugin": [
    [
      "./plugins/tui-smoke.tsx",
      {
        "enabled": false,
        "label": "workspace",
        "keybinds": {
          "smoke_modal": "ctrl+alt+m",
          "smoke_screen": "ctrl+alt+o",
          "smoke_screen_home": "escape,ctrl+shift+h",
          "smoke_screen_modal": "ctrl+alt+m",
          "smoke_dialog_close": "escape,q"
        }
      }
    ]
  ],
  // ZYRAXON-specific TUI settings
  "theme": {
    "primary": "#00ff00",
    "secondary": "#008800",
    "accent": "#ff8800",
    "background": "#000000",
    "foreground": "#ffffff"
  },
  "keybindings": {
    "stream_toggle": "ctrl+shift+s",
    "stream_quality_up": "ctrl+shift+q",
    "stream_quality_down": "ctrl+shift+w",
    "mcp_tools_toggle": "ctrl+shift+m",
    "agent_mode_toggle": "ctrl+shift+a",
    "memory_search": "ctrl+shift+f",
    "self_heal_toggle": "ctrl+shift+h",
    "tor_toggle": "ctrl+shift+t"
  },
  "display": {
    "show_streaming_status": true,
    "show_mcp_tools_count": true,
    "show_agent_mode": true,
    "show_memory_usage": true,
    "show_self_healing_status": true,
    "show_tor_status": true
  }
}
