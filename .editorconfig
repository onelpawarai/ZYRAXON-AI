root = true

[*]
charset = utf-8
insert_final_newline = true
end_of_line = lf
indent_style = space
indent_size = 2
max_line_length = 80

# ZYRAXON-specific settings
[*.ts]
indent_size = 2
max_line_length = 120

[*.tsx]
indent_size = 2
max_line_length = 120

[*.js]
indent_size = 2
max_line_length = 120

[*.jsx]
indent_size = 2
max_line_length = 120

[*.json]
indent_size = 2
max_line_length = 200

[*.jsonc]
indent_size = 2
max_line_length = 200

[*.md]
indent_size = 2
max_line_length = 80

[*.txt]
indent_size = 2
max_line_length = 80

[*.py]
indent_size = 4
max_line_length = 120

[Makefile]
indent_style = tab
